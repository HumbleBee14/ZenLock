<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft outer glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp"/>
            <solid android:color="#35818CF8"/>
            <padding android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp"/>
        </shape>
    </item>

    <!-- Main glass fill -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp"/>
            <gradient
                android:angle="135"
                android:startColor="#CC6366F1"
                android:centerColor="#C47C3AED"
                android:endColor="#BB8B5CF6"
                android:type="linear"/>
            <stroke
                android:width="1dp"
                android:color="#45FFFFFF"/>
        </shape>
    </item>

    <!-- Inner top shine (glass reflection) -->
    <item
        android:top="2dp"
        android:left="8dp"
        android:right="8dp"
        android:bottom="36dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp"
                android:bottomLeftRadius="10dp" android:bottomRightRadius="10dp"/>
            <gradient
                android:angle="90"
                android:startColor="#00FFFFFF"
                android:endColor="#25FFFFFF"
                android:type="linear"/>
        </shape>
    </item>

</layer-list>
