<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundPrimary"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            tools:context=".fragments.HomeFragment">

    <!-- Welcome Section -->
    <TextView
        android:id="@+id/welcomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus Time"
        style="@style/ModernText.PageTitle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/welcomeSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set your focus duration and lock distractions"
        style="@style/ModernText.Caption"
        app:layout_constraintTop_toBottomOf="@id/welcomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <!-- Timer Selection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/timerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/welcomeSubtitle">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Duration Mode: Clickable Time Display -->
            <LinearLayout
                android:id="@+id/timeDisplayContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="16dp">

                <TextView
                    android:id="@+id/selectedTimeDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:30"
                    android:textSize="64sp"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="-0.02"
                    android:layout_gravity="center"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="32sp"
                    android:autoSizeMaxTextSize="64sp"/>

                <TextView
                    android:id="@+id/durationModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hours : minutes"
                    android:textSize="11sp"
                    android:textColor="@color/textTertiary"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Lock Until Mode: Time Display (hidden by default) -->
            <LinearLayout
                android:id="@+id/lockUntilContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/lockUntilTimeDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:00 AM"
                    android:textSize="48sp"
                    android:textColor="@color/textPrimary"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="-0.02"
                    android:layout_gravity="center"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="28sp"
                    android:autoSizeMaxTextSize="48sp"/>

                <TextView
                    android:id="@+id/lockUntilLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lock Until"
                    android:textSize="11sp"
                    android:textColor="@color/textTertiary"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Time Controls with +/- buttons -->
            <LinearLayout
                android:id="@+id/durationControlsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/decreaseTimeButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="−"
                    android:textSize="24sp"
                    android:textColor="@color/textPrimary"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:backgroundTint="@color/backgroundSecondary"
                    app:rippleColor="@color/primaryLight"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="12dp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/preset15min"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+15m"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@android:color/transparent"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/preset30min"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+30m"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@android:color/transparent"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/preset60min"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+1h"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@android:color/transparent"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/increaseTimeButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="@color/textPrimary"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    app:backgroundTint="@color/backgroundSecondary"
                    app:rippleColor="@color/primaryLight"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginStart="12dp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

            </LinearLayout>

            <!-- Hidden NumberPickers for backward compatibility -->
            <LinearLayout
                android:id="@+id/timerSelectionContainer"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Hours Section -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hours"
                        style="@style/ModernText.Caption"
                        android:layout_marginBottom="8dp"/>

                    <NumberPicker
                        android:id="@+id/hoursPicker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:theme="@style/AppTheme.Picker"/>

                </LinearLayout>

                <!-- Minutes Section -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minutes"
                        style="@style/ModernText.Caption"
                        android:layout_marginBottom="8dp"/>

                    <NumberPicker
                        android:id="@+id/minutesPicker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:theme="@style/AppTheme.Picker"/>

                </LinearLayout>

            </LinearLayout>



        </LinearLayout>

        <!-- Mode Toggle: Duration / Lock Until -->
        <ImageButton
            android:id="@+id/modeToggleButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_schedule"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:contentDescription="Switch to lock until time"
            android:scaleType="fitCenter"
            app:tint="@color/textSecondary"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/startDelaySection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/timerCard">

        <LinearLayout
            android:id="@+id/startDelayRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="36dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Starts"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/startDelayValueContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="36dp"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/startDelayValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Now"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:id="@+id/startDelayChevron"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_expand_more"
                    app:tint="@color/textSecondary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Glassmorphic Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/enableLockButton"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:text="Start Focus"
        android:textSize="17sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.04"
        android:textAllCaps="false"
        android:background="@drawable/glassmorphic_button"
        android:elevation="6dp"
        app:icon="@drawable/ic_lock"
        app:iconGravity="textStart"
        app:iconTint="@color/white"
        app:iconSize="22dp"
        app:iconPadding="12dp"
        app:rippleColor="#40FFFFFF"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/startDelaySection"/>

    <!-- Subtle hint text -->
    <TextView
        android:id="@+id/startFocusHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Long press to begin"
        android:textSize="12sp"
        android:textColor="@color/textSecondary"
        android:fontFamily="sans-serif"
        android:alpha="0.7"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/enableLockButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Zen Progress Overlay -->
    <include layout="@layout/zen_mode_progress_overlay" />

</FrameLayout>
