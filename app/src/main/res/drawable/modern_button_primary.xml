<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#50FFFFFF">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="@color/white"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <!-- Soft outer glow -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="24dp"/>
                    <solid android:color="#30818CF8"/>
                    <padding android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="2dp"/>
                </shape>
            </item>
            <!-- Main fill: semi-transparent gradient -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="23dp"/>
                    <gradient
                        android:angle="135"
                        android:startColor="#D96366F1"
                        android:centerColor="#D07C3AED"
                        android:endColor="#CC8B5CF6"
                        android:type="linear"/>
                    <stroke
                        android:width="0.75dp"
                        android:color="#40FFFFFF"/>
                </shape>
            </item>
            <!-- Inner top highlight (glass shine) -->
            <item
                android:top="1dp"
                android:left="4dp"
                android:right="4dp"
                android:bottom="28dp">
                <shape android:shape="rectangle">
                    <corners android:topLeftRadius="22dp" android:topRightRadius="22dp"
                        android:bottomLeftRadius="8dp" android:bottomRightRadius="8dp"/>
                    <gradient
                        android:angle="90"
                        android:startColor="#00FFFFFF"
                        android:endColor="#22FFFFFF"
                        android:type="linear"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
