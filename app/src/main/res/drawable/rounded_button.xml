<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <layer-list>
            <!-- Main gradient with translucency -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp"/>
                    <gradient
                        android:angle="135"
                        android:startColor="#E06366F1"
                        android:centerColor="#E07C3AED"
                        android:endColor="#E08B5CF6"
                        android:type="linear"/>
                    <stroke
                        android:width="1dp"
                        android:color="#30FFFFFF"/>
                </shape>
            </item>
            <!-- Top glass reflection -->
            <item
                android:top="1dp"
                android:left="1dp"
                android:right="1dp"
                android:bottom="24dp">
                <shape android:shape="rectangle">
                    <corners
                        android:topLeftRadius="20dp"
                        android:topRightRadius="20dp"/>
                    <gradient
                        android:angle="90"
                        android:startColor="#00FFFFFF"
                        android:endColor="#18FFFFFF"
                        android:type="linear"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
