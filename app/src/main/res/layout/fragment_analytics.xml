<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundPrimary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".fragments.AnalyticsFragment">

        <!-- Header Section -->
        <TextView
            android:id="@+id/analyticsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insights"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/textPrimary"
            android:letterSpacing="0.02"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/analyticsSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your focus journey at a glance"
            style="@style/ModernText.Caption"
            app:layout_constraintTop_toBottomOf="@id/analyticsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"/>

        <!-- Usage Permission Banner -->
        <TextView
            android:id="@+id/usagePermissionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:text="Usage access required for full analytics. Tap to grant."
            android:textSize="13sp"
            android:textColor="@color/scoreGold"
            android:background="@drawable/glass_card_inner"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/analyticsSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- TODAY'S FOCUS — Hero Card with Focus Score  -->
        <!-- ═══════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/todayStatsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/usagePermissionBanner"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_timer"
                        app:tint="@color/primary"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Today's Focus"
                        style="@style/ModernText.SectionTitle"/>

                    <TextView
                        android:id="@+id/todayTrendIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="vs Yesterday"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:background="@drawable/gradient_accent_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                </LinearLayout>

                <!-- Hero Focus Score Ring -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_gravity="center">

                        <!-- Subtle glow behind ring -->
                        <View
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:background="@drawable/timer_glow_background" />

                        <ProgressBar
                            android:id="@+id/focusScoreProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_gravity="center"
                            android:indeterminate="false"
                            android:progress="85"
                            android:max="100"
                            android:progressDrawable="@drawable/circular_progress_zen" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/todayFocusScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="85"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/scoreGold"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FOCUS SCORE"
                                android:textSize="9sp"
                                android:textColor="@color/textTertiary"
                                android:fontFamily="sans-serif-medium"
                                android:textAllCaps="true"
                                android:letterSpacing="0.08"/>

                        </LinearLayout>

                    </FrameLayout>

                </FrameLayout>

                <!-- Stats Row: Sessions + Focus Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Sessions -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/glass_card_inner"
                        android:padding="16dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/todaySessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESSIONS"
                            style="@style/ModernText.MetricLabel"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <!-- Focus Time -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/glass_card_inner"
                        android:padding="16dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/todayTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0m"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryLight"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOCUS TIME"
                            style="@style/ModernText.MetricLabel"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Phone Usage / Time Saved Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_card_inner"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/textTertiary"
                            android:layout_marginEnd="6dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/todayMobileUsage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0m"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PHONE USAGE"
                                style="@style/ModernText.MetricLabel"/>

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/dividerSubtle"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_timer"
                            app:tint="@color/success"
                            android:layout_marginEnd="6dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/todayTimeSaved"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0m"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/success"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TIME SAVED"
                                style="@style/ModernText.MetricLabel"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Hidden progress bars (keep IDs for Java compatibility) -->
                <ProgressBar
                    android:id="@+id/sessionsProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:progress="0"
                    android:max="10"/>

                <ProgressBar
                    android:id="@+id/timeProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:progress="0"
                    android:max="480"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════ -->
        <!-- WEEKLY INSIGHTS — Expandable Card  -->
        <!-- ═══════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/focusTrendsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/todayStatsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/focusTrendsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Weekly Insights"
                        style="@style/ModernText.SectionTitle"/>

                    <ImageView
                        android:id="@+id/focusTrendsExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/textSecondary"
                        android:rotation="180"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/focusTrendsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:layout_marginTop="16dp">

                    <!-- Focus Time Card — Indigo accent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/stat_accent_left_indigo"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_timer"
                                app:tint="@color/primary"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Focus Time"
                                style="@style/ModernText.SectionTitle"/>

                            <TextView
                                android:id="@+id/weeklyFocusChange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:background="@drawable/gradient_accent_badge"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/thisWeekFocusTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="THIS WEEK"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/lastWeekFocusTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textSecondary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LAST WEEK"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Phone Usage Card — Amber accent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/stat_accent_left_amber"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/warning"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Phone Usage"
                                style="@style/ModernText.SectionTitle"/>

                            <TextView
                                android:id="@+id/weeklyMobileChange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:background="@drawable/gradient_accent_badge"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/thisWeekMobileUsage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textPrimary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="THIS WEEK"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/lastWeekMobileUsage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textSecondary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LAST WEEK"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Chart Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Focus Sessions"
                        style="@style/ModernText.SectionTitle"
                        android:layout_marginBottom="8dp"/>

                    <com.github.mikephil.charting.charts.CombinedChart
                        android:id="@+id/weeklyCombinedChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ════════════════════════════════════ -->
        <!-- MONTHLY INSIGHTS — Expandable Card  -->
        <!-- ════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/monthlyTrendsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/focusTrendsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/monthlyTrendsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Monthly Insights"
                        style="@style/ModernText.SectionTitle"/>

                    <ImageView
                        android:id="@+id/monthlyTrendsExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/textSecondary"
                        android:rotation="180"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/monthlyTrendsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:layout_marginTop="16dp">

                    <!-- Focus Time — Indigo accent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/stat_accent_left_indigo"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_timer"
                                app:tint="@color/primary"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Focus Time"
                                style="@style/ModernText.SectionTitle"/>

                            <TextView
                                android:id="@+id/monthlyFocusChange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:background="@drawable/gradient_accent_badge"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/thisMonthFocusTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="THIS MONTH"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/lastMonthFocusTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textSecondary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LAST MONTH"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Phone Usage — Amber accent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/stat_accent_left_amber"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/warning"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Phone Usage"
                                style="@style/ModernText.SectionTitle"/>

                            <TextView
                                android:id="@+id/monthlyMobileChange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:background="@drawable/gradient_accent_badge"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/thisMonthMobileUsage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textPrimary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="THIS MONTH"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/lastMonthMobileUsage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0m"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/textSecondary"
                                    android:fontFamily="sans-serif-medium"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LAST MONTH"
                                    style="@style/ModernText.MetricLabel"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Chart -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Focus Trend"
                        style="@style/ModernText.SectionTitle"
                        android:layout_marginBottom="8dp"/>

                    <com.github.mikephil.charting.charts.CombinedChart
                        android:id="@+id/monthlyCombinedChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════ -->
        <!-- RECENT SESSIONS — Expandable Card  -->
        <!-- ═══════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/recentSessionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/monthlyTrendsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/recentSessionsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Sessions"
                        style="@style/ModernText.SectionTitle"/>

                    <ImageView
                        android:id="@+id/recentSessionsExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/textSecondary"
                        android:rotation="180"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/recentSessionsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/recentSessionsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Complete your first session to see history here"
                        style="@style/ModernText.Caption"
                        android:textColor="@color/textTertiary"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone"/>

                    <!-- Dynamic session items populated by AnalyticsFragment.java -->
                    <LinearLayout
                        android:id="@+id/recentSessionsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
